# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in the real values for LOCAL development.
# On Render, these are set automatically (DATABASE_URL) or via the dashboard.

SECRET_KEY=your-random-secret-key
JWT_SECRET_KEY=your-random-jwt-secret-key

# Local PostgreSQL connection string
DATABASE_URL=postgresql://localhost/agx_farm_platform
